/**
 * Comprehensive test suite for the error handling system
 * This file tests all major components of the error handling implementation
 */

import { 
  BaseError, 
  ValidationError, 
  QueryExecutionError, 
  BudgetExceededError,
  SystemError,
  ErrorCapture,
  ErrorFramer,
  ErrorMonitoring,
  ErrorUtils,
  ErrorCategory,
  ErrorSeverity,
  ErrorLevel,
  Audience,
  ERROR_CODES
} from './core/errors/index.js';

/**
 * Test runner class for organizing and executing tests
 */
class ErrorHandlingTestRunner {
  private tests: Array<{ name: string; fn: () => boolean | Promise<boolean> }> = [];
  private passed = 0;
  private failed = 0;

  /**
   * Add a test to the runner
   */
  test(name: string, fn: () => boolean | Promise<boolean>) {
    this.tests.push({ name, fn });
  }

  /**
   * Run all tests and report results
   */
  async runAll(): Promise<void> {
    console.log('Starting Error Handling System Tests...\n');
    console.log('='.repeat(60));

    for (const test of this.tests) {
      try {
        console.log(`\nTEST: ${test.name}`);
        console.log('-'.repeat(40));
        
        const result = await test.fn();
        if (result) {
          console.log('PASSED');
          this.passed++;
        } else {
          console.log('FAILED');
          this.failed++;
        }
      } catch (error) {
        console.log('FAILED with exception:');
        console.log(error instanceof Error ? error.message : String(error));
        this.failed++;
      }
    }

    console.log('\n' + '='.repeat(60));
    console.log('TEST SUMMARY');
    console.log('='.repeat(60));
    console.log(`Total: ${this.tests.length}`);
    console.log(`Passed: ${this.passed}`);
    console.log(`Failed: ${this.failed}`);
    console.log(`Success Rate: ${((this.passed / this.tests.length) * 100).toFixed(1)}%`);
  }
}

/**
 * Test 1: Basic Error Creation and Properties
 */
function testBasicErrorCreation(): boolean {
  // Test BaseError creation
  const baseError = new BaseError(
    'Test error message',
    'TEST001',
    ErrorCategory.VALIDATION,
    ErrorSeverity.ERROR,
    ErrorLevel.NODE,
    { nodeId: 'test-node', operation: 'test-operation' }
  );

  const baseChecks = [
    baseError.message === 'Test error message',
    baseError.metadata.errorCode === 'TEST001',
    baseError.metadata.category === ErrorCategory.VALIDATION,
    baseError.metadata.severity === ErrorSeverity.ERROR,
    baseError.metadata.level === ErrorLevel.NODE,
    baseError.metadata.context.nodeId === 'test-node',
    baseError.userMessage === 'Test error message',
    baseError.technicalDetails === 'validation:TEST001 - Test error message'
  ];

  // Test ValidationError
  const validationError = new ValidationError(
    'Invalid input data',
    'VAL001',
    { nodeId: 'validator' },
    ['field1 is required', 'field2 must be numeric']
  );

  const validationChecks = [
    validationError.userMessage === 'The input data doesn\'t match the required format. Please check your data and try again.',
    validationError.recoverySuggestions.length > 0,
    validationError.recoverySuggestions[0].action === 'review_input_data'
  ];

  // Test QueryExecutionError
  const queryError = new QueryExecutionError(
    'SELECT * FROM users',
    new Error('Connection timeout'),
    { nodeId: 'query-executor' }
  );

  const queryChecks = [
    queryError.metadata.context.query === 'SELECT * FROM users',
    queryError.metadata.context.originalError === 'Connection timeout',
    queryError.userMessage === 'The database query couldn\'t be executed. This might be due to invalid data or a complex query.'
  ];

  return [...baseChecks, ...validationChecks, ...queryChecks].every(Boolean);
}

/**
 * Test 2: Error Capture and Aggregation
 */
async function testErrorCapture(): Promise<boolean> {
  const errorCapture = new ErrorCapture(100);

  // Create different types of errors
  const errors = [
    new ValidationError('Error 1', 'VAL001', { nodeId: 'node1' }),
    new ValidationError('Error 2', 'VAL002', { nodeId: 'node1' }),
    new QueryExecutionError('SELECT 1', new Error('DB Error'), { nodeId: 'node2' }),
    new BudgetExceededError('timeout', 120000, 60000, { nodeId: 'node3' })
  ];

  // Capture errors
  errors.forEach(error => errorCapture.captureError(error));

  // Test aggregation
  const summary = errorCapture.generateSummary();
  
  const checks = [
    summary.totalErrors === 4,
    summary.categories[ErrorCategory.VALIDATION]?.count === 2,
    summary.categories[ErrorCategory.EXECUTION]?.count === 1,
    summary.categories[ErrorCategory.RESOURCE]?.count === 1,
    summary.topErrors.length === 4,
    summary.recommendations.length > 0
  ];

  // Test filtering
  const validationErrors = errorCapture.getErrors({ category: ErrorCategory.VALIDATION });
  const node1Errors = errorCapture.getErrors({ nodeId: 'node1' });

  checks.push(
    validationErrors.length === 2,
    node1Errors.length === 2
  );

  // Test pattern detection
  const patterns = errorCapture.detectPatterns();
  checks.push(patterns.length >= 0); // Patterns may or may not be detected

  return checks.every(Boolean);
}

/**
 * Test 3: Error Response Framing
 */
function testErrorResponseFraming(): boolean {
  const error = new ValidationError('Test validation error', 'VAL001');

  // Test different audiences
  const userResponse = ErrorFramer.formatErrorResponse(error, Audience.USER);
  const developerResponse = ErrorFramer.formatErrorResponse(error, Audience.DEVELOPER);
  
  const userDisplay = ErrorFramer.formatForDisplay(error, Audience.USER);
  const developerDisplay = ErrorFramer.formatForDisplay(error, Audience.DEVELOPER);

  const checks = [
    // User response checks
    userResponse.error.message === error.userMessage,
    userResponse.error.technicalDetails === '',
    userResponse.error.recoverySuggestions.length > 0,
    userResponse.error.recoverySuggestions.some(s => s.type === 'manual'),
    
    // Developer response checks
    developerResponse.error.message === error.message,
    developerResponse.error.technicalDetails !== '',
    developerResponse.error.technicalDetails === error.technicalDetails,
    
    // Display formatting checks
    userDisplay.title.includes('Error'),
    userDisplay.message === error.userMessage,
    userDisplay.actions.length > 0,
    userDisplay.actions.some(a => a.type === 'primary'),
    
    // Developer display checks
    developerDisplay.details?.technical !== undefined,
    developerDisplay.details?.technical === error.technicalDetails
  ];

  // Test recovery message generation
  const recoveryMessage = ErrorFramer.generateRecoveryMessage(error);
  checks.push(
    recoveryMessage.includes('review'),
    recoveryMessage.includes('Success rate')
  );

  return checks.every(Boolean);
}

/**
 * Test 4: Error Monitoring and Analytics
 */
async function testErrorMonitoring(): Promise<boolean> {
  const errorMonitoring = new ErrorMonitoring({
    alertThresholds: {
      critical_error_rate: { value: 0.1, severity: ErrorSeverity.CRITICAL },
      total_error_rate: { value: 1.0, severity: ErrorSeverity.ERROR }
    },
    maxHistorySize: 100
  });

  // Add various errors
  const errors = [
    new ValidationError('Test error 1', 'VAL001'),
    new ValidationError('Test error 2', 'VAL002'),
    new BudgetExceededError('timeout', 120000, 60000),
    new SystemError('Critical failure', 'SYS001', ErrorSeverity.CRITICAL)
  ];

  errors.forEach(error => errorMonitoring.captureError(error));

  // Generate report
  const report = errorMonitoring.generateReport();
  
  const checks = [
    report.metrics.totalErrors === 4,
    report.metrics.errorsByCategory[ErrorCategory.VALIDATION] === 2,
    report.metrics.errorsByCategory[ErrorCategory.RESOURCE] === 1,
    report.metrics.errorsByCategory[ErrorCategory.SYSTEM] === 1,
    report.metrics.errorsBySeverity[ErrorSeverity.CRITICAL] === 1,
    report.summary.totalErrors === 4,
    report.period.duration > 0,
    report.recommendations.length > 0,
    report.trends !== undefined
  ];

  // Test alerts
  const alerts = errorMonitoring.getActiveAlerts();
  checks.push(
    alerts.length > 0,
    alerts.some(a => a.type === 'critical'),
    alerts.some(a => a.severity === ErrorSeverity.CRITICAL)
  );

  // Test report formatting
  const userReport = errorMonitoring.formatReportForUser(report);
  const developerReport = errorMonitoring.formatReportForDeveloper(report);
  
  checks.push(
    userReport.includes('Error Monitoring Report'),
    userReport.includes('Key Metrics'),
    developerReport.includes('Error Monitoring Report (Technical)'),
    developerReport.includes('Metrics:')
  );

  return checks.every(Boolean);
}

/**
 * Test 5: Error Utilities
 */
function testErrorUtilities(): boolean {
  // Test error wrapping
  const regularError = new Error('Regular error message');
  const wrappedError = ErrorUtils.wrapError(regularError, { nodeId: 'test-node' });

  // Test utility functions
  const validationError = new ValidationError('Test validation', 'VAL001');
  const criticalError = new BaseError(
    'Critical system failure',
    'CRIT001',
    ErrorCategory.SYSTEM,
    ErrorSeverity.CRITICAL
  );

  const checks = [
    // Error wrapping
    wrappedError instanceof BaseError,
    wrappedError.message === 'Regular error message',
    wrappedError.metadata.context.nodeId === 'test-node',
    
    // Recovery detection
    ErrorUtils.isRecoverable(validationError),
    !ErrorUtils.isRecoverable(criticalError),
    
    // Escalation detection
    ErrorUtils.shouldEscalate(criticalError),
    !ErrorUtils.shouldEscalate(validationError),
    
    // Best recovery suggestion
    ErrorUtils.getBestRecoverySuggestion(validationError) !== null,
    
    // Correlation context
    (() => {
      const context = ErrorUtils.createCorrelationContext('exec-123', 'pipe-456', 'node-789');
      return context.executionId === 'exec-123' && 
             context.pipelineId === 'pipe-456' && 
             context.nodeId === 'node-789';
    })(),
    
    // Logging format
    (() => {
      const logFormat = ErrorUtils.formatForLogging(validationError);
      return logFormat.includes('VAL001') && 
             logFormat.includes('validation') && 
             logFormat.includes('Test validation');
    })(),
    
    // Metrics extraction
    (() => {
      const metrics = ErrorUtils.extractMetrics(validationError);
      return metrics.error_count === 1 && 
             metrics.error_category === 'validation' &&
             metrics.error_severity === 'error';
    })()
  ];

  return checks.every(Boolean);
}

/**
 * Test 6: Error Code Constants
 */
function testErrorCodes(): boolean {
  const checks = [
    ERROR_CODES.VALIDATION_FAILED === 'VAL001',
    ERROR_CODES.QUERY_EXECUTION_FAILED === 'EXE001',
    ERROR_CODES.BUDGET_EXCEEDED === 'RES001',
    ERROR_CODES.DATABASE_CONNECTION_FAILED === 'SYS002',
    ERROR_CODES.DATA_NOT_FOUND === 'DAT001',
    ERROR_CODES.CONNECTION_FAILED === 'NET001'
  ];

  return checks.every(Boolean);
}

/**
 * Test 7: Error Context and Metadata
 */
function testErrorContext(): boolean {
  // Test error with rich context
  const error = new BaseError(
    'Complex error',
    'COMP001',
    ErrorCategory.SYSTEM,
    ErrorSeverity.ERROR,
    ErrorLevel.PIPELINE,
    {
      nodeId: 'complex-node',
      pipelineId: 'pipeline-123',
      executionId: 'exec-456',
      sessionId: 'session-789',
      component: 'TestComponent',
      operation: 'testOperation',
      inputMetadata: { rows: 100, size: '1MB' },
      environment: { nodeVersion: '18.0.0', platform: 'linux' },
      customField: 'custom value'
    }
  )
    .withTag('test-tag')
    .withTag('another-tag')
    .withMetrics({ executionTime: 1500, memoryUsage: 256 })
    .withCause(ErrorUtils.wrapError(new Error('Root cause')));

  const checks = [
    error.metadata.context.nodeId === 'complex-node',
    error.metadata.context.pipelineId === 'pipeline-123',
    error.metadata.context.executionId === 'exec-456',
    error.metadata.context.customField === 'custom value',
    error.metadata.tags?.includes('test-tag'),
    error.metadata.tags?.includes('another-tag'),
    error.metadata.metrics?.executionTime === 1500,
    error.metadata.metrics?.memoryUsage === 256,
    error.metadata.cause?.message === 'Root cause'
  ];

  // Test JSON serialization
  const json = error.toJSON();
  checks.push(
    json.name === 'BaseError',
    json.message === 'Complex error',
    json.metadata.errorCode === 'COMP001',
    json.recoverySuggestions.length >= 0
  );

  return checks.every(Boolean);
}

/**
 * Test 8: Integration with Execution Trace
 */
function testExecutionTraceIntegration(): boolean {
  // This test would require the execution trace system
  // For now, we'll test the basic structure
  try {
    // Import trace functions
    const { traceError, extractErrorsFromTrace } = require('./core/context/execution-trace.js');
    
    // Create a mock trace
    const mockTrace = {
      events: []
    };

    // Test trace error function exists
    const checks = [
      typeof traceError === 'function',
      typeof extractErrorsFromTrace === 'function'
    ];

    return checks.every(Boolean);
  } catch (error) {
    // If trace system isn't available, skip this test
    console.log('Skipping trace integration test - trace system not available');
    return true;
  }
}

/**
 * Main test runner execution
 */
async function runAllTests(): Promise<void> {
  const runner = new ErrorHandlingTestRunner();

  // Add all tests
  runner.test('Basic Error Creation and Properties', testBasicErrorCreation);
  runner.test('Error Capture and Aggregation', testErrorCapture);
  runner.test('Error Response Framing', testErrorResponseFraming);
  runner.test('Error Monitoring and Analytics', testErrorMonitoring);
  runner.test('Error Utilities', testErrorUtilities);
  runner.test('Error Code Constants', testErrorCodes);
  runner.test('Error Context and Metadata', testErrorContext);
  runner.test('Execution Trace Integration', testExecutionTraceIntegration);

  // Run all tests
  await runner.runAll();
}

/**
 * Demonstration function for manual testing
 */
function demonstrateErrorHandling(): void {
  console.log('\n=== Error Handling System Demonstration ===\n');

  // Create different error types
  const validationError = new ValidationError(
    'Input data validation failed',
    'VAL001',
    { nodeId: 'user-input-validator' },
    ['email is required', 'age must be positive']
  );
  
  const queryError = new QueryExecutionError(
    'SELECT * FROM users WHERE active = true',
    new Error('Connection timeout'),
    { nodeId: 'user-query-executor' }
  );
  
  const budgetError = new BudgetExceededError(
    'timeout',
    120000,
    60000,
    { executionId: 'exec-456' }
  );

  console.log('1. Created Different Error Types:');
  console.log(`   - Validation Error: ${validationError.userMessage}`);
  console.log(`   - Query Error: ${queryError.userMessage}`);
  console.log(`   - Budget Error: ${budgetError.userMessage}`);

  // Test error capture
  const errorCapture = new ErrorCapture(100);
  [validationError, queryError, budgetError].forEach(error => errorCapture.captureError(error));
  
  const summary = errorCapture.generateSummary();
  console.log('\n2. Error Capture Summary:');
  console.log(`   - Total Errors: ${summary.totalErrors}`);
  console.log(`   - Categories: ${Object.keys(summary.categories).filter(cat => (summary.categories[cat as ErrorCategory]?.count ?? 0) > 0).join(', ')}`);

  // Test response formatting
  const userResponse = ErrorFramer.formatErrorResponse(validationError, Audience.USER);
  console.log('\n3. User-Friendly Response:');
  console.log(`   - Message: ${userResponse.error.message}`);
  console.log(`   - Recovery Suggestions: ${userResponse.error.recoverySuggestions.length}`);

  // Test monitoring
  const monitoring = new ErrorMonitoring();
  [validationError, queryError, budgetError].forEach(error => monitoring.captureError(error));
  
  const report = monitoring.generateReport();
  console.log('\n4. Monitoring Report:');
  console.log(`   - Error Rate: ${report.metrics.errorRate.toFixed(2)}/min`);
  console.log(`   - Active Alerts: ${report.alerts.length}`);
  console.log(`   - Recommendations: ${report.recommendations.length}`);
}

// Export functions for external use
export {
  runAllTests,
  demonstrateErrorHandling,
  ErrorHandlingTestRunner,
  testBasicErrorCreation,
  testErrorCapture,
  testErrorResponseFraming,
  testErrorMonitoring,
  testErrorUtilities,
  testErrorCodes,
  testErrorContext,
  testExecutionTraceIntegration
};

// Run tests if this file is executed directly
if (import.meta.url === `file://${process.argv[1]}`) {
  runAllTests().then(() => {
    demonstrateErrorHandling();
  }).catch(error => {
    console.error('Test execution failed:', error);
    process.exit(1);
  });
}
